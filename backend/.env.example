# MongoDB
MONGODB_URI=mongodb://localhost:27017/sasekor-helper

# Telegram
BOT_TOKEN=
TELEGRAM_GROUP_ID=

# Auth
JWT_SECRET=   # at least 32 random chars; e.g. openssl rand -hex 32

# Admin (email+password login)
ADMIN_EMAIL=admin@example.com
# Bun's dotenv expands `$VAR` even inside quotes, so every `$` in the argon2id
# hash must be backslash-escaped (`\$argon2id\$v=19\$m=...`). Run:
#   bun run hash-password
# and paste the line it prints — the script does the escaping for you.
ADMIN_PASSWORD_HASH=
# 24-char hex. Generate: bun -e 'import {ObjectId} from "mongodb"; console.log(new ObjectId().toHexString())'
ADMIN_USER_ID=

# Server
PORT=8080
TZ=Asia/Phnom_Penh
NODE_ENV=development

# Frontend allowed origin (CORS). Leave empty for dev (allows any origin reflectively,
# but only safe with credentials when no auth cookies are issued from production builds).
# In development set to http://localhost:3000 to enable credentialed requests from the
# local Next.js frontend. When FRONTEND_ORIGIN is "*", browsers reject credentials:true
# requests entirely — this is the safer default for production until a real origin is set.
FRONTEND_ORIGIN=
